<%- include('header.ejs') %> 
 
 
 
 <main class="dashboard-content">
        <div class="container-fluid px-3 px-lg-4 py-4">
          <div class="page-heading">
            <div class="page-heading-copy">
              <span class="page-icon"><i class="bi bi-file-earmark" aria-hidden="true"></i></span>
              <div>
                <p class="eyebrow mb-1">Starter</p>
                <h1 class="h3 mb-1">Appointment</h1>
              </div>
            </div>
            
          </div>

          <section class="panel">
            
            <form action="appointment_search" method="get" class="mb-5">
              <label>Form</label>
              <input type="date" name="from_date">
              <label>To</label>
              <input type="date" name="to_date">
              <label>Status</label >
              <select name="status">
                <option>Choose</option>
                <option>Pending</option>
                <option>Confirm</option>
                <option>Reject</option>
              </select>
              <button class="btn btn-dark">Search</button>
            </form>
            
             <table class="table table-border mb5">
              <tr>
                    <th>Sr.No</th>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Service</th>
                    <th>Date</th>
                    <th>Status</th>
                    <th>Action</th>
               </tr>
               
               <% for(var i=0;i<data.length;i++) { %>
                <tr>
                    <td><%= i+1 %></td>
                    <td><%= data[i].name %></td>
                    <td><%= data[i].email %></td>
                    <td><%= data[i].service_id %></td>
                    <td><%= new Date(data[i].appointment_date).toLocaleDateString('en-GB') %></td>
                    <td><%= data[i].status %></td>
                     <td>
                        <a href="/admin/appointment_confirm/<%= data[i].aid %>"><button class="btn btn-warning mb-2">Confirm</button></a>
                        <a href="/admin/appointment_reject/<%= data[i].aid %>"><button class="btn btn-danger" >Reject</button></a>
                     </td>
                </tr>
                <% } %>
             </table> 

            
          </section>
        </div>
      </main>


      <%- include('footer.ejs') %>