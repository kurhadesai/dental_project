<%- include('header.ejs') %>



<body>
  <div class="admin-shell">
    <div class="sidebar-backdrop" data-sidebar-close></div>

    <aside class="admin-sidebar" id="adminSidebar" aria-label="Main navigation">
      <div class="sidebar-header">
        <a class="brand-mark" href="index-2.html" aria-label="adminHMD dashboard">
          <span class="brand-icon"><i class="bi bi-grid-1x2-fill" aria-hidden="true"></i></span>
          <span class="brand-copy">
            <span class="brand-title">adminSk</span>
            <span class="brand-subtitle">Admin Template</span>
          </span>
        </a>
      </div>

      

      

      <div class="sidebar-footer">
        <span class="status-dot"></span>
        <span class="sidebar-footer-text">System running smoothly</span>
      </div>
    </aside>

    <div class="admin-main">
      <nav class="navbar admin-navbar navbar-expand bg-white">
        <div class="container-fluid px-3 px-lg-4">
          <button class="sidebar-toggle" type="button" data-sidebar-toggle aria-controls="adminSidebar" aria-expanded="true" aria-label="Toggle sidebar">
            <span></span>
            <span></span>
            <span></span>
          </button>

          <form class="d-none d-md-flex ms-3 flex-grow-1" role="search">
            <input class="form-control search-input" type="search" placeholder="Search users, orders, reports" aria-label="Search">
          </form>

          <div class="navbar-actions ms-auto">
            <button class="icon-button theme-toggle" type="button" data-theme-toggle aria-label="Switch color theme" title="Switch color theme">
              <i class="bi bi-moon-stars" data-theme-icon aria-hidden="true"></i>
            </button>
            <div class="dropdown">
              <button class="icon-button" type="button" data-bs-toggle="dropdown" aria-expanded="false" aria-label="Notifications">
                <span class="notification-dot"></span>
                <i class="bi bi-bell" aria-hidden="true"></i>
              </button>
              <div class="dropdown-menu dropdown-menu-end notification-menu">
                <div class="dropdown-header fw-bold text-body">Notifications</div>
                <a class="dropdown-item" href="users.html">
                  <span class="notification-title">New user registered</span>
                  <span class="notification-time">4 minutes ago</span>
                </a>
                <a class="dropdown-item" href="charts.html">
                  <span class="notification-title">Revenue target reached</span>
                  <span class="notification-time">32 minutes ago</span>
                </a>
                <a class="dropdown-item" href="settings.html">
                  <span class="notification-title">Security review completed</span>
                  <span class="notification-time">1 hour ago</span>
                </a>
              </div>
            </div>

            <div class="dropdown">
              <button class="profile-button dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                <img class="avatar-img avatar-sm" src="../assets/images/avatar/avatar.jpg" alt="Admin Hasan">
                <span class="profile-name d-none d-sm-inline">Admin Sai</span>
              </button>
              <ul class="dropdown-menu dropdown-menu-end">
                <li><a class="dropdown-item" href="profile.html">Profile</a></li>
                <li><a class="dropdown-item" href="settings.html">Account settings</a></li>
                <li><hr class="dropdown-divider"></li>
                <li><a class="dropdown-item" href="/admin/logout">Sign out</a></li>
              </ul>
            </div>
          </div>
        </div>
      </nav>

      <main class="dashboard-content">
    <div class="container-fluid px-3 px-lg-4 py-4">

        <div class="page-heading">
            <div class="page-heading-copy">
                <span class="page-icon">
                    <i class="bi bi-currency-dollar" aria-hidden="true"></i>
                </span>
                <div>
                    <p class="eyebrow mb-1">Starter</p>
                    <h1 class="h3 mb-1">Pricing</h1>
                </div>
            </div>
        </div>

        <section class="panel">

            <form action="/admin/Pricing_save" method="POST">

                <label>Title</label>
                <input type="text" class="form-control mb-3" name="ptitle">

                <label>Sub Title</label>
                <input type="text" class="form-control mb-3" name="psubtitle">

                <label>Price</label>
                <input type="text" class="form-control mb-3" name="pprice">

                <label>Feature 1</label>
                <input type="text" class="form-control mb-3" name="pfeature1">

                <label>Feature 2</label>
                <input type="text" class="form-control mb-3" name="pfeature2">

                <label>Feature 3</label>
                <input type="text" class="form-control mb-3" name="pfeature3">

                <label>Feature 4</label>
                <input type="text" class="form-control mb-4" name="pfeature4">

                <button class="btn btn-primary">Save</button>

            </form>

            <hr>

            <table class="table table-bordered ">

                <tr>
                    <th>Sr.No</th>
                    <th>Title</th>
                    <th>Sub Title</th>
                    <th>Price</th>
                    <th>Feature 1</th>
                    <th>Feature 2</th>
                    <th>Feature 3</th>
                    <th>Feature 4</th>
                    <th>Action</th>
                </tr>

                <% for(var i=0;i<pricing.length;i++){ %>

                <tr>
                    <td><%= i+1 %></td>

                    <td><%= pricing[i].ptitle %></td>

                    <td><%= pricing[i].psubtitle %></td>

                    <td><%= pricing[i].pprice %></td>

                    <td><%= pricing[i].pfeature1 %></td>

                    <td><%= pricing[i].pfeature2 %></td>

                    <td><%= pricing[i].pfeature3 %></td>

                    <td><%= pricing[i].pfeature4 %></td>

                    <td>
                        <a href="/admin/Pricing_edit/<%= pricing[i].pid %>">
                            <button class="btn btn-warning mb-2">
                                Edit
                            </button>
                        </a>

                        <a href="/admin/Pricing_delete/<%= pricing[i].pid %>">
                            <button class="btn btn-danger">
                                Delete
                            </button>
                        </a>
                    </td>
                </tr>

                <% } %>

            </table>

        </section>

    </div>
</main>

      


    <%- include('footer.ejs') %>
