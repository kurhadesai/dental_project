<%- include('header.ejs') %>
        <!-- Hero Section -->
        <section class="hero-section d-flex align-items-center">
            <div class="container text-center">

                <h1 class="hero-title">
                    Transparent & Affordable Dental Pricing
                </h1>

                <p class="hero-text">
                    Clear treatment plans with flexible and reasonable pricing
                    options.
                </p>

                <a href="#" class="btn hero-btn px-5 py-2">
                    Book an Appointment
                </a>

            </div>
        </section>
        <!-- Pricing Section -->
        <section class="container py-5">

            <div class="text-center mb-4">
                <h2 class="fw-bold">Pricing Plans</h2>
                <p class="text-muted">
                    Choose the dental care plan that best fits your treatment
                    needs.
                </p>
            </div>
            <div class="row g-4">

                <!-- Basic Plan -->
                 <% for(var i=0;i<pricing.length;i++){ %>
                <div class="col-md-4">
                    <div class="price-card">

                        <h5 class="fw-bold"><%= pricing[i].ptitle %></h5>
                        <p class="text-muted"><%= pricing[i].psubtitle %></p>

                        <h2 class="price"><%= pricing[i].pprice %></h2>

                        <ul class="price-list">
                            <li><%= pricing[i].pfeature1 %></li>
                            <li><%= pricing[i].pfeature2 %></li>
                            <li><%= pricing[i].pfeature3 %></li>
                            <li><%= pricing[i].pfeature4 %></li>
                        </ul>

                        <a href="#" class="btn price-btn">Choose Plan</a>
                    </div>
                </div>
                 <% } %>
            </div>
        </section>
        <!-- Appointment Section -->
        <section class="container my-5">

            <div class="row align-items-stretch g-0 no-gap">

                <!-- Text Column (With Background & Circles) -->
                <div class="col-md-7">
                    <div class="appointment-box p-5">

                        <h3 class="fw-bold text-white">
                            Need Help Choosing the Right Plan?
                        </h3>

                        <p class="text-white-50">
                            Book a consultation and our doctors will guide you
                            to the best treatment option.

                        </p>

                        <a class="btn btn-light px-4 fw-semibold">
                            Book an Appointment
                        </a>

                    </div>
                </div>

                <!-- Image Column -->
                <div class="col-md-5">
                    <img src="web/img/picing.jpg"
                        class="equal-img">
                </div>

            </div>

        </section>
        <!-- Footer Section -->
        <%- include('footer.ejs') %>